DEEPSEEK_API_KEY=sk-...          # required — for text extraction
OPENAI_API_KEY=sk-...            # optional — only needed for ENABLE_VISION=true

# ── The following are configured via Web UI (python web.py) ──────────────────
# FB_GROUP_URLS, TARGET_BUDGET, MAX_BUDGET, MAX_MOVE_IN_COST,
# MIN_SIZE_SQM, MUST_HAVE_WASHER, NEED_PARKING,
# MAX_SCROLL_ROUNDS, MAX_POSTS_PER_RUN, HEADLESS

# ── CLI-only overrides (optional) ────────────────────────────────────────────
# PREFERRED_AREAS=On Nut,Udom Suk,Ari,Huai Khwang
# PREFERRED_STATIONS=BTS On Nut,BTS Udom Suk,MRT Huai Khwang
PET_FRIENDLY=false
PREFERRED_ROOM_TYPES=studio,1br
ENABLE_VISION=false
DEEPSEEK_MODEL=deepseek-v4-flash
VISION_MODEL=gpt-4o-mini

# Alerts & cleanup
ALERT_MIN_TIER=shortlist
DATA_RETENTION_DAYS=30
